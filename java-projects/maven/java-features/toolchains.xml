<?xml version="1.0" encoding="UTF-8"?>
<toolchains xmlns="http://maven.apache.org/TOOLCHAINS/1.1.0"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://maven.apache.org/TOOLCHAINS/1.1.0
            https://maven.apache.org/xsd/toolchains-1.1.0.xsd">

    <!-- Java 8 -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>8</version>
        </provides>
        <configuration>
            <jdkHome>/Library/Java/JavaVirtualMachines/zulu-8.jdk/Contents/Home</jdkHome>
        </configuration>
    </toolchain>

    <!-- Java 11 -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>11</version>
        </provides>
        <configuration>
            <jdkHome>/Library/Java/JavaVirtualMachines/zulu-11.jdk/Contents/Home</jdkHome>
        </configuration>
    </toolchain>

    <!-- Java 17 -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>17</version>
        </provides>
        <configuration>
            <jdkHome>/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home</jdkHome>
        </configuration>
    </toolchain>

    <!-- Java 21 -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>21</version>
        </provides>
        <configuration>
            <jdkHome>/Library/Java/JavaVirtualMachines/zulu-21.jdk/Contents/Home</jdkHome>
        </configuration>
    </toolchain>

    <!-- Java 25 -->
    <toolchain>
        <type>jdk</type>
        <provides>
            <version>25</version>
        </provides>
        <configuration>
            <jdkHome>/Library/Java/JavaVirtualMachines/zulu-25.jdk/Contents/Home</jdkHome>
        </configuration>
    </toolchain>

</toolchains>